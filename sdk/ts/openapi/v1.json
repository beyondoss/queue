  "components": {
    "schemas": {
      "ChangeVisibilityRequest": {
        "type": "object",
        "required": [
          "vt"
        ],
        "properties": {
          "vt": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "ChangeVisibilityResponse": {
        "type": "object",
        "required": [
          "id",
          "visible_at"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "visible_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateQueueRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "fifo": {
            "type": "boolean"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "DeleteBatchRequest": {
        "type": "object",
        "required": [
          "ids"
        ],
        "properties": {
          "ids": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            }
          }
        }
      },
      "DeletedResponse": {
        "type": "object",
        "required": [
          "deleted"
        ],
        "properties": {
          "deleted": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "required": [
          "id",
          "read_count",
          "enqueued_at",
          "visible_at",
          "message"
        ],
        "properties": {
          "enqueued_at": {
            "type": "string",
            "format": "date-time"
          },
          "headers": {},
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "message": {},
          "read_count": {
            "type": "integer",
            "format": "int32"
          },
          "visible_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PurgeResponse": {
        "type": "object",
        "required": [
          "deleted"
        ],
        "properties": {
          "deleted": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "QueueMetricsResponse": {
        "type": "object",
        "required": [
          "name",
          "queue_length",
          "total_messages",
          "scrape_time"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "newest_msg_age_sec": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "oldest_msg_age_sec": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "queue_length": {
            "type": "integer",
            "format": "int64"
          },
          "scrape_time": {
            "type": "string",
            "format": "date-time"
          },
          "total_messages": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "QueueResponse": {
        "type": "object",
        "required": [
          "name",
          "is_partitioned",
          "is_unlogged",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "is_partitioned": {
            "type": "boolean"
          },
          "is_unlogged": {
            "type": "boolean"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "SendBody": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/SendRequest"
          },
          {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SendRequest"
            }
          }
        ]
      },
      "SendRequest": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "delay": {
            "type": "integer",
            "format": "int32"
          },
          "group_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "headers": {},
          "message": {}
        }
      },
      "SendResponse": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "ids"
            ],
            "properties": {
              "ids": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "format": "int64"
                }
              }
            }
          }
        ]
      },
      "SubscribeRequest": {
        "type": "object",
        "properties": {
          "endpoint": {
            "type": [
              "string",
              "null"
            ]
          },
          "envelope": {
            "type": "boolean",
            "description": "Opt-in to SNS notification envelope; default false means raw payload delivery."
          },
          "protocol": {
            "type": [
              "string",
              "null"
            ]
          },
          "queue_name": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "TopicMessage": {
        "type": "object",
        "required": [
          "queue_name",
          "msg_id"
        ],
        "properties": {
          "msg_id": {
            "type": "integer",
            "format": "int64"
          },
          "queue_name": {
            "type": "string"
          }
        }
      },
      "TopicSendRequest": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "delay": {
            "type": "integer",
            "format": "int32"
          },
          "headers": {},
          "message": {}
        }
      },
      "TopicSendResponse": {
        "type": "object",
        "required": [
          "queues_matched",
          "messages"
        ],
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TopicMessage"
            }
          },
          "queues_matched": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "TopicSubscription": {
        "type": "object",
        "required": [
          "id",
          "pattern",
          "protocol",
          "endpoint",
          "bound_at",
          "raw_delivery"
        ],
        "properties": {
          "bound_at": {
            "type": "string",
            "format": "date-time"
          },
          "endpoint": {
            "type": "string"
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "pattern": {
            "type": "string"
          },
          "protocol": {
            "type": "string"
          },
          "queue_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "raw_delivery": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "queues",
      "description": "Queue lifecycle and metrics"
    },
    {
      "name": "messages",
      "description": "Send, receive, delete, and visibility"
    },
    {
      "name": "events",
      "description": "Topic fan-out and subscriptions"
    }
  ]
}
