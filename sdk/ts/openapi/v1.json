    "/v1/queues/{name}/messages": {
      "get": {
        "tags": [
          "messages"
        ],
        "operationId": "receive_messages",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Queue name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max",
            "in": "query",
            "description": "Maximum number of messages to return. Default: 1.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "wait",
            "in": "query",
            "description": "Long-poll wait time in seconds. Default: 0 (no wait).",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "vt",
            "in": "query",
            "description": "Visibility timeout in seconds. Default: 30.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "fifo",
            "in": "query",
            "description": "Return messages in FIFO order within a group. Default: false.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageResponse"
                  }
                }
              }
            }
          },
          "404": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "messages"
        ],
        "operationId": "send_messages",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Queue name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "async_commit",
            "in": "query",
            "description": "Skip WAL fsync on commit. Improves throughput at the cost of durability:\nmessages can be lost on a PostgreSQL crash. Default: false (durable).",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
