{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            name,\n            expression,\n            cron,\n            fire_at,\n            timezone,\n            jitter_secs,\n            catchup,\n            catchup_limit,\n            failure_threshold,\n            target_kind::TEXT AS \"target_kind!\",\n            target_name,\n            payload,\n            headers,\n            status::TEXT AS \"status!\",\n            next_fire_at,\n            last_fired_at,\n            last_error,\n            consecutive_failures,\n            fire_count,\n            created_at,\n            updated_at\n        FROM queue.schedule\n        WHERE status = 'active' AND next_fire_at <= now()\n        ORDER BY next_fire_at\n        LIMIT $1\n        FOR UPDATE SKIP LOCKED\n        ",
